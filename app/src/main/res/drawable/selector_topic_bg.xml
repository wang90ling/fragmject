<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <stroke android:width="0dp" android:color="#ffffffff" />
            <gradient android:angle="180" android:centerColor="#E3DBFF" android:endColor="#fadcea" android:startColor="#E4F6FF" android:type="linear" android:useLevel="true" />
            <corners android:bottomLeftRadius="17dp" android:bottomRightRadius="17dp" android:topLeftRadius="17dp" android:topRightRadius="17dp" />
        </shape>
    </item>
    <item android:state_selected="false">
        <shape android:shape="rectangle">
            <solid android:color="#fff6f7f9" />
            <corners android:topLeftRadius="19dp" android:topRightRadius="19dp" android:bottomLeftRadius="19dp" android:bottomRightRadius="19dp" />
        </shape>
    </item>
</selector>