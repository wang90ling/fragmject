<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottom_tab_layout"
    android:layout_width="match_parent"
    android:layout_height="65dp">

    <View
        android:id="@+id/line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_F6F6F6"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/tab_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@+id/line"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/tab_CP"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:background="@drawable/profile_social_tab_normal"
            android:orientation="vertical">
            <TextView
                android:id="@+id/title_CP"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:drawableStart="@drawable/ic_tv_cp_normal"
                android:includeFontPadding="false"
                android:paddingHorizontal="12dp"
                android:textColor="@color/color_A2A2A2"
                android:textSize="12sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/tab_teacher"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:visibility="gone"
            android:background="@drawable/profile_social_tab_normal"
            android:orientation="vertical">
            <TextView
                android:id="@+id/title_teacher"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:fontFamily="sans-serif"
                android:text="师徒"
                android:textColor="@color/color_A2A2A2"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/tab_guard"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:gravity="center"
            android:layout_marginStart="10dp"
            android:background="@drawable/profile_social_tab_normal"
            android:orientation="vertical">
            <TextView
                android:id="@+id/title_guard"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:fontFamily="sans-serif"
                android:text="守护"
                android:textColor="@color/color_A2A2A2"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/tab_friend"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:gravity="center"
            android:layout_marginStart="10dp"
            android:background="@drawable/profile_social_tab_normal"
            android:orientation="vertical">
            <TextView
                android:id="@+id/title_friend"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:fontFamily="sans-serif"
                android:text="红蓝颜"
                android:textColor="@color/color_A2A2A2"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

