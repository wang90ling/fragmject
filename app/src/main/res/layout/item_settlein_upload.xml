<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.zhpan.bannerview.BannerViewPager
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:bvp_auto_play="true"
            app:bvp_can_loop="true"
            app:bvp_indicator_checked_color="@color/color_FFCA38"
            app:bvp_indicator_gravity="end"
            app:bvp_indicator_normal_color="@color/color_50_FFFFFF"
            app:bvp_indicator_style="round_rect"
            app:bvp_interval="3000"
            app:bvp_scroll_duration="300" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>