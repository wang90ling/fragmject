<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <import type="pw.z.imchat.util.PersonInfoHelper" />

        <variable
            name="item"
            type="pw.z.dianta.bean.response.SearchResponse" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="7dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingHorizontal="4dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/shape_circle_avatar"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical"
                app:layout_constrainedWidth="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/iv_avatar"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <pw.z.dianta.view.MultiHighlightTextView
                        android:id="@+id/nick_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxWidth="129dp"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text='@{item.nickName == null ? "" : item.nickName}'
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="111111111111111111111111111111111111111111" />

                    <TextView
                        android:id="@+id/tv_age"
                        android:layout_width="wrap_content"
                        android:layout_height="15dp"
                        android:layout_marginStart="6dp"
                        android:background='@{item.sex.equals("w") ? @drawable/bg_profile_sex_age_wm : @drawable/bg_profile_sex_age_m}'
                        android:drawableStart='@{(item.sex== null) ? null : (item.sex.equals("w") ? @drawable/ic_new_sex_wm : @drawable/ic_new_sex_man)}'
                        android:drawablePadding="1dp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="4dp"
                        android:text='@{"" + item.age}'
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:visibility="@{item.age == null ? View.GONE : View.VISIBLE}"
                        tools:background="@drawable/bg_profile_sex_age_wm"
                        tools:text="11" />

                </LinearLayout>

                <TextView
                    android:id="@+id/people_served_num_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_A2A2A2"
                    android:textSize="13sp"
                    tools:text="8000299" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
