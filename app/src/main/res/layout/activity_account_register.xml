<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/drawable_one_click_login_bg">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="13dp"
        android:layout_marginTop="10dp"
        android:src="@drawable/dt_ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="55dp"
        android:src="@drawable/ic_login_page_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_back" />

    <TextView
        android:id="@+id/tv_phone_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="19dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/color_80_010101"
        android:textSize="21sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_logo"
        tools:text="150****7777" />

    <TextView
        android:id="@+id/tv_register"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="33dp"
        android:layout_marginTop="51dp"
        android:background="@drawable/shape_def_button"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="一键注册"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/tv_phone_number" />

    <pw.z.dianta.view.AgreementCheckBox
        android:id="@+id/agreement_checkbox"
        android:layout_width="match_parent"
        android:layout_height="25dp"
        android:layout_marginHorizontal="33dp"
        android:layout_marginTop="19dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="19dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_register"
        app:linkTextColor="@color/color_95_010101"
        app:normalTextColor="@color/color_30_010101" />

</androidx.constraintlayout.widget.ConstraintLayout>