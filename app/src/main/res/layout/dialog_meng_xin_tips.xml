<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_meng_xin_tips"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="260dp"
        android:layout_marginHorizontal="20dp"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:lines="1"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:text="规则说明"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />
        <TextView
            android:id="@+id/content_index_one"
            android:layout_width="25dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="left"
            android:textColor="@color/color_75_010101"
            android:textSize="16sp"
            android:text="1."
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title"/>

        <TextView
            android:id="@+id/content_one"
            android:layout_width="235dp"
            android:layout_height="wrap_content"
            android:gravity="left"
            android:textColor="@color/color_75_010101"
            android:textSize="16sp"
            android:text="萌新广场仅限主播身份可见，展示平台内萌新用户，快速与用户建立联系。"
            app:layout_constraintStart_toEndOf="@+id/content_index_one"
            app:layout_constraintTop_toTopOf="@+id/content_index_one"/>

        <TextView
            android:id="@+id/content_index_two"
            android:layout_width="25dp"
            android:layout_height="wrap_content"
            android:gravity="left"
            android:textColor="@color/color_75_010101"
            android:textSize="16sp"
            android:text="2."
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/content_one"/>

        <TextView
            android:id="@+id/content_two"
            android:layout_width="235dp"
            android:layout_height="wrap_content"
            android:gravity="left"
            android:textColor="@color/color_75_010101"
            android:textSize="16sp"
            android:text="可随机刷新已充值过的高价值新用户，在列表内标识，人数有限先到先得。"
            app:layout_constraintStart_toEndOf="@+id/content_index_two"
            app:layout_constraintTop_toTopOf="@+id/content_index_two"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/color_10_010101" />

    <TextView
        android:id="@+id/ok_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/color_8C7DFC"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:layout_margin="15dp"
        android:text="我知道了"/>
</LinearLayout>