<?xml version="1.0" encoding="utf-8"?>
<com.small.uikit.ui.layout.UiConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:background_normal="#1F1C32"
    app:corner_radius_top_left="19dp"
    app:corner_radius_top_right="19dp">

    <TextView
        android:id="@+id/filter_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingVertical="19dp"
        android:text="@string/home_recommend_filter_title"
        android:textColor="#80FFFFFF"
        android:textSize="19sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/filter_rv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:overScrollMode="never"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/filter_title" />

    <View
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="@drawable/top_shadow"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom" />

    <LinearLayout
        android:id="@+id/ll_bottom"
        android:layout_width="match_parent"
        android:layout_height="83dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.small.uikit.ui.view.UiTextView
            android:id="@+id/filter_reset"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="13dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1.5"
            android:gravity="center"
            android:text="@string/dt_c_reset"
            android:textColor="#80FFFFFF"
            android:textSize="15sp"
            app:background_normal="#34314B"
            app:corner_radius="29dp" />

        <com.small.uikit.ui.view.UiTextView
            android:id="@+id/filter_confirm"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="13dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/dt_c_confirm"
            android:textColor="@color/white"
            android:textSize="15sp"
            app:background_normal="#8C7DFC"
            app:corner_radius="29dp" />

    </LinearLayout>

</com.small.uikit.ui.layout.UiConstraintLayout>