<?xml version="1.0" encoding="utf-8"?>
<pw.z.baselibrary.view.nsvrv.ChildNestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nsl_cp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_cp_self"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_cp"
            android:layout_width="match_parent"
            android:layout_height="198dp"
            android:layout_marginHorizontal="13.5dp"
            android:background="@drawable/social_guard_normal_bg"
            app:layout_constraintDimensionRatio="333:198"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_cp_self_line_left"
                android:layout_width="67dp"
                android:layout_height="67dp"
                android:layout_marginTop="84dp"
                android:layout_marginStart="27dp"
                android:src="@drawable/social_guard_avatar_bg"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/iv_cp_self_line_right"
                android:layout_width="67dp"
                android:layout_height="67dp"
                android:layout_marginTop="84dp"
                android:layout_marginEnd="27dp"
                android:src="@drawable/social_guard_avatar_bg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/iv_cp_self_seat_left"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:src="@drawable/ic_cp_seat"
                app:layout_constraintTop_toTopOf="@id/iv_cp_self_line_left"
                app:layout_constraintBottom_toBottomOf="@id/iv_cp_self_line_left"
                app:layout_constraintStart_toStartOf="@id/iv_cp_self_line_left"
                app:layout_constraintEnd_toEndOf="@id/iv_cp_self_line_left"/>

            <ImageView
                android:id="@+id/iv_cp_self_seat_right"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:src="@drawable/ic_cp_seat"
                app:layout_constraintTop_toTopOf="@id/iv_cp_self_line_right"
                app:layout_constraintBottom_toBottomOf="@id/iv_cp_self_line_right"
                app:layout_constraintStart_toStartOf="@id/iv_cp_self_line_right"
                app:layout_constraintEnd_toEndOf="@id/iv_cp_self_line_right"/>


            <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
                android:id="@+id/iv_cp_self_seat_left_avatar"
                android:layout_width="57dp"
                android:layout_height="57dp"
                android:scaleType="centerCrop"
                app:corner_radius="57dp"
                app:layout_constraintBottom_toBottomOf="@id/iv_cp_self_seat_left"
                app:layout_constraintEnd_toEndOf="@id/iv_cp_self_seat_left"
                app:layout_constraintStart_toStartOf="@id/iv_cp_self_seat_left"
                app:layout_constraintTop_toTopOf="@id/iv_cp_self_seat_left" />

            <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
                android:id="@+id/iv_cp_self_seat_right_avatar"
                android:layout_width="57dp"
                android:layout_height="57dp"
                android:scaleType="centerCrop"
                app:corner_radius="57dp"
                app:layout_constraintBottom_toBottomOf="@id/iv_cp_self_seat_right"
                app:layout_constraintEnd_toEndOf="@id/iv_cp_self_seat_right"
                app:layout_constraintStart_toStartOf="@id/iv_cp_self_seat_right"
                app:layout_constraintTop_toTopOf="@id/iv_cp_self_seat_right" />

            <TextView
                android:id="@+id/tv_cp_self_seat_left_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_guard_name"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:maxWidth="100dp"
                android:includeFontPadding="false"
                android:paddingHorizontal="13dp"
                android:paddingVertical="4dp"
                android:textColor="#946AFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintEnd_toEndOf="@id/iv_cp_self_seat_left"
                app:layout_constraintStart_toStartOf="@id/iv_cp_self_seat_left"
                app:layout_constraintTop_toBottomOf="@id/iv_cp_self_seat_left"
                tools:text="自己自己自己自己自己" />

            <TextView
                android:id="@+id/tv_cp_self_seat_right_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_guard_name"
                android:gravity="center"
                android:includeFontPadding="false"
                android:paddingHorizontal="13dp"
                android:paddingVertical="4dp"
                android:text="@string/cp_self_wait"
                android:textColor="#946AFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintEnd_toEndOf="@id/iv_cp_self_seat_right"
                app:layout_constraintStart_toStartOf="@id/iv_cp_self_seat_right"
                app:layout_constraintTop_toBottomOf="@id/iv_cp_self_seat_right" />

            <TextView
                android:id="@+id/tv_cp_self_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="99dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="LV.2" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_guard_value_layout"
                android:layout_width="98dp"
                android:layout_height="27dp"
                android:layout_marginTop="146dp"
                android:background="@drawable/social_guard_btn_bg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/cl_guard_value"
                    android:layout_width="wrap_content"
                    android:layout_height="15dp"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:maxWidth="100dp"
                    android:textColor="#946AFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:text="亲密值：999w" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_cp_gift"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="38dp"
            android:background="#FFFF00"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cl_cp">

            <pw.z.baselibrary.view.nsvrv.ChildRecyclerView
                android:id="@+id/rv_create"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:spanCount="3" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</pw.z.baselibrary.view.nsvrv.ChildNestedScrollView>