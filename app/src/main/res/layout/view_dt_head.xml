<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="14dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bulletin_cl"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="13dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintDimensionRatio="334:142"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/banner_fl"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginVertical="5dp"
            android:layout_marginEnd="4dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/home_jddt"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.zhpan.bannerview.BannerViewPager
                android:id="@+id/recommend_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:bvp_auto_play="true"
                app:bvp_can_loop="true"
                app:bvp_indicator_checked_color="@color/color_60_FFFFFF"
                app:bvp_indicator_gravity="end"
                app:bvp_indicator_normal_color="@color/color_60_FFFFFF"
                app:bvp_indicator_style="round_rect"
                app:bvp_interval="3000"
                app:bvp_scroll_duration="300" />
        </FrameLayout>

        <ImageView
            android:id="@+id/home_jddt"
            android:layout_width="135dp"
            android:layout_height="0dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_home_jddt"
            app:layout_constrainedWidth="true"
            app:layout_constraintDimensionRatio="432:231"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/home_kspp"
            android:layout_width="135dp"
            android:layout_height="0dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_home_kspp"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="434:236"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:layout_marginStart="8dp"
        android:background="@android:color/transparent"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@+id/category_more_iv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bulletin_cl"
        app:tabGravity="start"
        app:tabIndicator="@null"
        app:tabIndicatorColor="@android:color/transparent"
        app:tabIndicatorHeight="0dp"
        app:tabMinWidth="37dp"
        app:tabMode="scrollable"
        app:tabPaddingBottom="0dp"
        app:tabPaddingEnd="5dp"
        app:tabPaddingStart="5dp"
        app:tabPaddingTop="0dp"
        app:tabRippleColor="@android:color/transparent"
        app:tabSelectedTextColor="@color/white"
        app:tabTextColor="@color/color_85_010101" />

    <ImageView
        android:id="@+id/category_more_iv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_home_game_more_new_year"
        app:layout_constraintBottom_toBottomOf="@+id/tabLayout"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="2dp"
        app:layout_constraintTop_toTopOf="@+id/tabLayout" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/filter_result_rv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="13dp"
        android:layout_marginTop="5dp"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@+id/category_filter_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tabLayout" />

    <TextView
        android:id="@+id/category_filter_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="@string/home_recommend_filter_title"
        android:textColor="@color/color_40_010101"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/filter_result_rv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/filter_result_rv" />
</androidx.constraintlayout.widget.ConstraintLayout>