<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_tab_accompany"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tv_tab_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="7dp"
        android:includeFontPadding="false"
        android:paddingHorizontal="6dp"
        android:paddingBottom="6dp"
        android:textColor="@color/color_85_010101"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="游戏实力" />

    <View
        android:id="@+id/v_indicator_1"
        android:layout_width="25dp"
        android:layout_height="3dp"
        android:background="@drawable/shape_accompany_detail_indiator"
        android:includeFontPadding="false"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="@id/tv_tab_1"
        app:layout_constraintStart_toStartOf="@id/tv_tab_1"
        app:layout_constraintTop_toBottomOf="@id/tv_tab_1" />

    <TextView
        android:id="@+id/tv_tab_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="7dp"
        android:includeFontPadding="false"
        android:paddingHorizontal="6dp"
        android:paddingBottom="6dp"
        android:textColor="@color/color_40_010101"
        android:textSize="15sp"
        app:layout_constraintStart_toEndOf="@id/tv_tab_1"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Ta的高光" />

    <View
        android:id="@+id/v_indicator_2"
        android:layout_width="25dp"
        android:layout_height="3dp"
        android:background="@drawable/shape_accompany_detail_indiator"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="@id/tv_tab_2"
        app:layout_constraintStart_toStartOf="@id/tv_tab_2"
        app:layout_constraintTop_toBottomOf="@id/tv_tab_2" />
</androidx.constraintlayout.widget.ConstraintLayout>