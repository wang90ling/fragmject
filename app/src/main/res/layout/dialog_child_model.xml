<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:layout_width="273dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scaleType="fitXY"
            android:src="@drawable/ic_dialog_child_model_bg" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="99dp"
            android:orientation="vertical"
            android:paddingHorizontal="15dp"
            android:paddingVertical="13dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/dialog_child_model_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/dialog_child_model_title"
                android:textColor="#d9000000"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/dialog_child_model_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:lineHeight="20dp"
                android:text="@string/dialog_child_model_content"
                android:textColor="#66000000"
                android:textSize="13sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/btn_close_child_model"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="13dp"
                android:background="@drawable/shape_8c7dfc_r23"
                android:gravity="center"
                android:includeFontPadding="false"
                android:paddingVertical="5dp"
                android:text="@string/close_child_model"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/btn_know"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="13dp"
                android:background="@drawable/shape_8c7dfc_r23"
                android:gravity="center"
                android:includeFontPadding="false"
                android:paddingVertical="5dp"
                android:text="@string/ps_know"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.cardview.widget.CardView>

</FrameLayout>
