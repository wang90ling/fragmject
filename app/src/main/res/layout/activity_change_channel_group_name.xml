<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:orientation="vertical">

    <pw.z.baselibrary.view.CustomTitleBar
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:moreText="@string/save"
        app:moreTextColor="#d9010101"
        app:moreTextSize="15sp"
        app:moreType="text"
        app:showBack="true"
        app:showMore="true"
        app:titleText="@string/change_channel_group_name" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginHorizontal="13dp"
        android:layout_marginTop="19dp"
        android:background="@drawable/shape_ffffff_r13"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleBar">

        <EditText
            android:id="@+id/et_name"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginHorizontal="12dp"
            android:layout_weight="1"
            android:background="@color/white"
            android:ellipsize="end"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_vertical"
            android:lines="1"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="#d9000000"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="屁酱的频道屁酱的频道屁酱的频道屁酱的频道屁酱的频道" />

        <TextView
            android:id="@+id/tv_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:textColor="#33010101"
            android:textSize="13sp"
            tools:text="7/15" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>