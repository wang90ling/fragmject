<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@drawable/bg_nj_header_hot_subject"
    tools:layout_height="120dp">

    <ImageView
        android:id="@+id/iv_hot_subject_left"
        android:layout_width="8dp"
        android:layout_height="15dp"
        android:src="@drawable/ic_nj_hot_subject_left"
        app:layout_constraintBottom_toTopOf="@id/cl_banner_hot_subject"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_hot_subject"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginBottom="1dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="热门话题"
        android:textColor="#ff120c41"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="@font/alimama_shuheiti"
        app:layout_constraintBottom_toBottomOf="@id/iv_hot_subject_left"
        app:layout_constraintStart_toEndOf="@id/iv_hot_subject_left"
        app:layout_constraintTop_toTopOf="@id/iv_hot_subject_left" />

    <ImageView
        android:id="@+id/iv_hot_subject_right"
        android:layout_width="8dp"
        android:layout_height="15dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_nj_hot_subject_right"
        app:layout_constraintStart_toEndOf="@id/tv_hot_subject"
        app:layout_constraintTop_toTopOf="@id/iv_hot_subject_left" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_hot_subject_more"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableEnd="@drawable/ic_nj_hot_subject_more"
        android:text="更多"
        android:textColor="#66120c41"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@id/iv_hot_subject_left"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_hot_subject_left" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_banner_hot_subject"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/shape_ffffff_r10"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="143:67"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <pw.z.dianta.view.NjHeaderHotSubjectBannerVP
            android:id="@+id/banner_hot_subject"
            android:layout_width="wrap_content"
            android:layout_height="17dp"
            app:bvp_auto_play="true"
            app:bvp_can_loop="true"
            app:bvp_indicator_visibility="gone"
            app:bvp_interval="5000"
            app:bvp_page_style="multi_page"
            app:bvp_scroll_duration="5000"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="陈泽杯(三角洲行动阿鹏加班开心话题开庭" />

        <FrameLayout
            android:id="@+id/fl_avatars"
            android:layout_width="wrap_content"
            android:layout_height="15dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <FrameLayout
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="20dp"
                android:background="@drawable/shape_ffffff_r15">

                <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
                    android:id="@+id/room_member_3"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:corner_radius="13dp"
                    tools:src="@color/green" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="10dp"
                android:background="@drawable/shape_ffffff_r15">

                <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
                    android:id="@+id/room_member_2"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:corner_radius="13dp"
                    tools:src="@color/read_dot_bg" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center_vertical|start"
                android:background="@drawable/shape_ffffff_r15">

                <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
                    android:id="@+id/room_member_1"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:corner_radius="13dp"
                    tools:src="@color/black" />
            </FrameLayout>
        </FrameLayout>

        <com.opensource.svgaplayer.SVGAImageView
            android:id="@+id/svga_nj_hotsubject_yuyintiao"
            android:layout_width="12dp"
            android:layout_height="10dp"
            android:layout_marginStart="5dp"
            app:autoPlay="true"
            app:fillMode="Forward"
            app:layout_constraintBottom_toBottomOf="@id/fl_avatars"
            app:layout_constraintStart_toEndOf="@id/fl_avatars"
            app:layout_constraintTop_toTopOf="@id/fl_avatars"
            app:loopCount="999999"
            app:source="nj_hotsubject_yuyintiao.svga" />

        <TextView
            android:id="@+id/tv_nj_hotsubject_notempty_ing"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="正在讨论"
            android:textColor="#998c7dfc"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="@id/fl_avatars"
            app:layout_constraintStart_toEndOf="@id/svga_nj_hotsubject_yuyintiao"
            app:layout_constraintTop_toTopOf="@id/fl_avatars" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>