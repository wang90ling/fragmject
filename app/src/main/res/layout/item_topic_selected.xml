<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minHeight="19dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/selector_topic_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="1dp">
        <TextView
            android:id="@+id/tv_topic_id"
            android:layout_width="1px"
            android:layout_height="1px"/>

        <TextView
            android:id="@+id/tv_topic_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="2dp"
            android:textColor="#80010101"
            android:textSize="12sp"
            app:drawableStartCompat="@drawable/ic_topic_small"
            tools:text="我pick的大神" />

        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_select_close" />
    </LinearLayout>
</FrameLayout>