<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <pw.z.baselibrary.view.CustomTitleBar
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        app:layout_constraintTop_toTopOf="parent"
        app:titleText="@string/settle_in_edit_title" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_F7F7F7"
        android:paddingHorizontal="13dp"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toTopOf="@+id/submit_btn_ll"
        app:layout_constraintTop_toBottomOf="@+id/titleBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="16dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/call_info_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_ffffff_r13"
                android:paddingVertical="13dp"
                android:visibility="visible">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="@color/color_8C7DFC"
                    app:layout_constraintBottom_toBottomOf="@+id/call_info_title"
                    app:layout_constraintDimensionRatio="4:17"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/call_info_title" />

                <TextView
                    android:id="@+id/call_info_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:includeFontPadding="false"
                    android:text="@string/call_info_title"
                    android:textColor="@color/color_85_000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/call_info_tip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="5dp"
                    android:includeFontPadding="false"
                    android:text="@string/call_info_tip"
                    android:textColor="@color/color_40_010101"
                    android:textSize="10sp"
                    app:layout_constraintStart_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/call_info_title" />

                <EditText
                    android:id="@+id/call_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/shape_f2f2f2_r8"
                    android:hint="@string/settelin_call_edit_tip"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/color_010101"
                    android:textColorHint="@color/color_20_010101"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@+id/call_info_tip" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/level_screenshot_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="19dp"
                android:background="@drawable/shape_ffffff_r13"
                android:paddingVertical="13dp"
                tools:visibility="visible">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="@color/color_8C7DFC"
                    app:layout_constraintBottom_toBottomOf="@+id/level_screenshot_title"
                    app:layout_constraintDimensionRatio="4:17"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/level_screenshot_title" />

                <TextView
                    android:id="@+id/level_screenshot_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:includeFontPadding="false"
                    android:text="@string/level_screenshot_title"
                    android:textColor="@color/color_85_000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/add_level_screenshot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:includeFontPadding="false"
                    android:text="@string/add_level_screenshot_title"
                    android:textColor="@color/color_8C7DFC"
                    android:textFontWeight="500"
                    android:textSize="12sp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@+id/level_screenshot_title"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/level_screenshot_title" />

                <TextView
                    android:id="@+id/level_screenshot_title_tip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:includeFontPadding="false"
                    android:text="@string/level_screenshot_title_tip"
                    android:textColor="@color/color_20_000000"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@+id/level_screenshot_title"
                    app:layout_constraintTop_toBottomOf="@+id/level_screenshot_title" />


                <androidx.cardview.widget.CardView
                    android:layout_width="150dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/level_screenshot_title_tip">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/iv_sample"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_settlein_slt" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/shape_8c7dfc_br_r8"
                            android:includeFontPadding="false"
                            android:paddingHorizontal="5dp"
                            android:paddingVertical="1dp"
                            android:text="示例图"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />
                    </RelativeLayout>

                </androidx.cardview.widget.CardView>


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/level_screenshot_rv"
                    android:layout_width="150dp"
                    android:layout_height="72dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:nestedScrollingEnabled="false"
                    android:orientation="vertical"
                    android:overScrollMode="never"
                    android:scrollbars="none"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/level_screenshot_title_tip" />


                <LinearLayout
                    android:id="@+id/info_edit_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@+id/level_screenshot_rv" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/highlight_video_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="19dp"
                android:background="@drawable/shape_ffffff_r13"
                android:paddingVertical="13dp"
                android:visibility="gone">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="@color/color_8C7DFC"
                    app:layout_constraintBottom_toBottomOf="@+id/highlight_video_title"
                    app:layout_constraintDimensionRatio="4:17"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/highlight_video_title" />

                <TextView
                    android:id="@+id/highlight_video_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:includeFontPadding="false"
                    android:text="@string/highlight_video_title"
                    android:textColor="@color/color_85_000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/highlight_video_rv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    android:orientation="vertical"
                    android:overScrollMode="never"
                    android:scrollbars="none"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@+id/highlight_video_title" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/user_info_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="19dp"
                android:background="@drawable/shape_ffffff_r13"
                android:paddingVertical="13dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="@color/color_8C7DFC"
                    app:layout_constraintBottom_toBottomOf="@+id/user_info_title"
                    app:layout_constraintDimensionRatio="4:17"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/user_info_title" />

                <TextView
                    android:id="@+id/user_info_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:includeFontPadding="false"
                    android:text="@string/user_info_title"
                    android:textColor="@color/color_85_000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/user_info_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/shape_f2f2f2_r8"
                    android:gravity="top|start"
                    android:hint="@string/settelin_userinfo_edit_tip"
                    android:maxLength="100"
                    android:minHeight="115dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/color_010101"
                    android:textColorHint="@color/color_20_010101"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@+id/user_info_title" />

                <TextView
                    android:id="@+id/user_info_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="8dp"
                    android:text="0/100"
                    android:textColor="@color/color_15_010101"
                    android:textSize="11sp"
                    app:layout_constraintBottom_toBottomOf="@+id/user_info_edit"
                    app:layout_constraintEnd_toEndOf="@+id/user_info_edit" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/recording_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="19dp"
                android:background="@drawable/shape_ffffff_r13"
                android:paddingVertical="13dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="@color/color_8C7DFC"
                    app:layout_constraintBottom_toBottomOf="@+id/recording_title"
                    app:layout_constraintDimensionRatio="4:17"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/recording_title" />

                <TextView
                    android:id="@+id/recording_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:includeFontPadding="false"
                    android:text="@string/recording_title"
                    android:textColor="@color/color_85_000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/goRecord"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:drawableEnd="@drawable/drawable_record_arrow_13"
                    android:text="@string/goRcord"
                    android:textColor="@color/color_8C7DFC"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@+id/recording_title"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/recording_title" />

                <LinearLayout
                    android:id="@+id/recording_file_ll"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/shape_settlein_record_file_bg"
                    android:gravity="center"
                    android:minWidth="60dp"
                    android:paddingHorizontal="7dp"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="@+id/recording_title"
                    app:layout_constraintTop_toBottomOf="@+id/recording_title">

                    <ImageView
                        android:id="@+id/iv_voice_play"
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:src="@drawable/ic_home_voice_play" />

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp">

                        <ImageView
                            android:id="@+id/iv_voice_yuyin"
                            android:layout_width="14dp"
                            android:layout_height="8dp"
                            android:src="@drawable/ll_voice_yuyin" />

                        <com.opensource.svgaplayer.SVGAImageView
                            android:id="@+id/iv_voice_anim"
                            android:layout_width="14dp"
                            android:layout_height="8dp"
                            app:source="ic_voice_anim.svga"
                            app:autoPlay="false"/>

                    </FrameLayout>

                    <TextView
                        android:id="@+id/recording_file_time_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:textColor="@color/color_8C7DFC"
                        android:textSize="10sp"
                        tools:text="6''" />
                </LinearLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="19dp"
                android:layout_marginBottom="50dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/kind_reminder"
                    android:textColor="@color/color_70_000000"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="@string/kind_reminder_tip"
                    android:textColor="@color/color_FF494C"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/submit_btn_ll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingHorizontal="13dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/submit_btn"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_centerInParent="true"
            android:background="@drawable/shape_def_button_r23"
            android:gravity="center"
            android:text="@string/submit"
            android:textColor="@color/white"
            app:layout_constraintDimensionRatio="333:44"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>