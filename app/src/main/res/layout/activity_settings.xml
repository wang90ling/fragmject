<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_F7F7F7">

    <pw.z.baselibrary.view.CustomTitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="@color/white"
        app:layout_constraintDimensionRatio="360:42"
        app:layout_constraintTop_toTopOf="parent"
        app:showBack="true"
        app:titleText="@string/setting_title" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toTopOf="@+id/log_out_btn"
        app:layout_constraintTop_toBottomOf="@+id/title_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.tencent.qcloud.tuikit.timcommon.component.LineControllerView
                android:id="@+id/setting_account_management"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                app:arrowSize="13dp"
                app:backgroundDrawable="@drawable/shape_ffffff"
                app:canNav="true"
                app:name="@string/setting_account_management" />

            <com.tencent.qcloud.tuikit.timcommon.component.LineControllerView
                android:id="@+id/setting_message_notification"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                app:arrowSize="13dp"
                app:backgroundDrawable="@drawable/shape_ffffff"
                app:canNav="true"
                app:name="@string/setting_message_notification" />

            <com.tencent.qcloud.tuikit.timcommon.component.LineControllerView
                android:id="@+id/setting_shared_info_list"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                app:arrowSize="13dp"
                app:backgroundDrawable="@drawable/shape_ffffff"
                app:canNav="true"
                app:name="@string/setting_shared_info_list" />

            <com.tencent.qcloud.tuikit.timcommon.component.LineControllerView
                android:id="@+id/setting_account_switch"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                app:arrowSize="13dp"
                app:backgroundDrawable="@drawable/shape_ffffff"
                app:canNav="true"
                app:name="账号切换" />

            <com.tencent.qcloud.tuikit.timcommon.component.LineControllerView
                android:id="@+id/setting_accessibility"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:visibility="gone"
                app:arrowSize="13dp"
                app:backgroundDrawable="@drawable/shape_ffffff"
                app:canNav="true"
                app:name="@string/setting_accessibility" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/shape_ffffff"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="榜单隐身"
                    android:textAlignment="viewStart"
                    android:textColor="@color/dt_color_85_010101"
                    android:textSize="15sp" />

                <pw.z.dianta.view.UiSwitchView
                    android:id="@+id/swRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:sb_background="#E9E9E9"
                    app:sb_button_color="#FFFFFF"
                    app:sb_checked_color="#8C7DFC"
                    app:sb_enable_check="false"
                    app:sb_show_indicator="false"
                    app:sb_uncheck_color="#FFFFFF" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/shape_ffffff"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="进房隐身"
                    android:textAlignment="viewStart"
                    android:textColor="@color/dt_color_85_010101"
                    android:textSize="15sp" />

                <pw.z.dianta.view.UiSwitchView
                    android:id="@+id/swRoom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:sb_background="#E9E9E9"
                    app:sb_button_color="#FFFFFF"
                    app:sb_checked_color="#8C7DFC"
                    app:sb_enable_check="false"
                    app:sb_show_indicator="false"
                    app:sb_uncheck_color="#FFFFFF" />

            </LinearLayout>

            <com.tencent.qcloud.tuikit.timcommon.component.LineControllerView
                android:id="@+id/setting_clear_cache"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                app:backgroundDrawable="@drawable/shape_ffffff"
                app:contentIsSelectable="false"
                app:name="@string/setting_clear_cache" />

            <com.tencent.qcloud.tuikit.timcommon.component.LineControllerView
                android:id="@+id/setting_about"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                app:backgroundDrawable="@drawable/shape_ffffff"
                app:contentIsSelectable="false"
                app:name="@string/setting_about" />

            <com.tencent.qcloud.tuikit.timcommon.component.LineControllerView
                android:id="@+id/setting_color_egg"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:contentIsSelectable="false" />

            <LinearLayout
                android:id="@+id/setting_app_info"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/shape_ffffff"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="APP信息悬浮窗"
                    android:textAlignment="viewStart"
                    android:textColor="@color/dt_color_85_010101"
                    android:textSize="15sp" />

                <pw.z.dianta.view.UiSwitchView
                    android:id="@+id/app_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:sb_background="#E9E9E9"
                    app:sb_button_color="#FFFFFF"
                    app:sb_checked_color="#8C7DFC"
                    app:sb_enable_check="false"
                    app:sb_show_indicator="false"
                    app:sb_uncheck_color="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/log_out_btn"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="13dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/shape_def_button"
        android:gravity="center"
        android:text="@string/log_out"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="333:44"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>