<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="57dp"
    android:layout_marginVertical="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:id="@+id/v_select_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_ebecf0_r8"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:ellipsize="end"
            android:lines="1"
            android:maxWidth="123dp"
            android:maxLines="1"
            android:textColor="@color/color_85_010101"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/tv_channel_id"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="永劫无间官方社区永劫无间官方社区" />

        <TextView
            android:id="@+id/tv_channel_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#33010101"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/tv_channel_name"
            app:layout_constraintTop_toBottomOf="@id/tv_channel_name"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="ID：1234" />

        <TextView
            android:id="@+id/tv_hot_value"
            android:layout_width="wrap_content"
            android:layout_height="15dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/shape_bg_hot_value"
            android:drawableStart="@drawable/ic_channel_hot"
            android:drawablePadding="3dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="2dp"
            android:textColor="#b3fe606f"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="@id/tv_channel_name"
            app:layout_constraintStart_toEndOf="@id/tv_channel_name"
            app:layout_constraintTop_toTopOf="@id/tv_channel_name"
            tools:text="251" />

        <TextView
            android:id="@+id/tv_join"
            android:layout_width="54dp"
            android:layout_height="27dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="13dp"
            android:background="@drawable/ic_channel_join"
            android:gravity="center"
            android:text="@string/join"
            android:textColor="@color/white"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>