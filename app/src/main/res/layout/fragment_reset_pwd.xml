<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <pw.z.baselibrary.view.CustomTitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:titleText="@string/reset_pwd" />

    <LinearLayout
        android:id="@+id/phone_ll"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="33dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/shape_edit_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintDimensionRatio="295:54"
        app:layout_constraintTop_toBottomOf="@+id/title_bar">

        <TextView
            android:id="@+id/phone_tv"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:clickable="false"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_vertical"
            android:hint="@string/login_hint_phone"
            android:lines="1"
            android:maxLines="1"
            android:paddingHorizontal="19dp"
            android:singleLine="true"
            android:textColor="@color/color_95_010101"
            android:textColorHint="@color/color_20_010101"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/et_pwd_vc_ll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="33dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/shape_edit_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintDimensionRatio="295:54"
        app:layout_constraintTop_toBottomOf="@+id/phone_ll">

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/input_ed_pwd"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:gravity="center_vertical"
            android:hint="@string/login_hint_input_pwd"
            android:inputType="textPassword"
            android:lines="1"
            android:maxLines="1"
            android:paddingHorizontal="19dp"
            android:singleLine="true"
            android:textColor="@color/color_95_010101"
            android:textColorHint="@color/color_20_010101"
            android:textSize="15sp"
            android:textStyle="bold" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/complete_btn"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="33dp"
        android:layout_marginTop="80dp"
        android:background="@drawable/shape_def_button"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="@string/complete"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        app:layout_constraintDimensionRatio="295:44"
        app:layout_constraintTop_toBottomOf="@+id/et_pwd_vc_ll" />
</androidx.constraintlayout.widget.ConstraintLayout>