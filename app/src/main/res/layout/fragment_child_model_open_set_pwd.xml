<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <pw.z.baselibrary.view.CustomTitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:showBack="true"
        app:titleText="@string/sam_teenager" />

    <TextView
        android:id="@+id/tv_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/set_password"
        android:textColor="#d9000000"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_bar" />

    <pw.z.baselibrary.view.PasswordView
        android:id="@+id/passwordView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="19dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_set"
        app:password_box_highLight_backgroundDrawable="@drawable/shape_child_pwd_bg"
        app:password_box_hasInput_backgroundDrawable="@drawable/shape_child_pwd_bg"
        app:password_box_notInput_backgroundDrawable="@drawable/shape_child_pwd_bg"
        app:password_box_setNumber="4"
        app:password_box_setSize="56"
        app:password_enableCursor="true"
        app:password_enableHideCode="true"
        app:password_text_setInputType="Number" />

</androidx.constraintlayout.widget.ConstraintLayout>