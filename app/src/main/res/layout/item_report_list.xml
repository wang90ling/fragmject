<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="13dp"
    android:background="@drawable/shape_ffffff_r13">

    <TextView
        android:id="@+id/tv_report_content"
        android:layout_width="54dp"
        android:layout_height="19dp"
        android:text="@string/report_content"
        android:textColor="#d9010101"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_report_people"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/report_for_people"
        android:textColor="#b2010101"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="@id/tv_report_content"
        app:layout_constraintTop_toBottomOf="@id/tv_report_content" />

    <TextView
        android:id="@+id/tv_report_people_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="不吃香菜的小李"
        android:textColor="#b2010101"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tv_report_people"
        app:layout_constraintStart_toEndOf="@+id/tv_report_people"
        app:layout_constraintTop_toTopOf="@id/tv_report_people" />

    <TextView
        android:id="@+id/tv_report_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/report_time"
        android:textColor="#b2010101"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="@id/tv_report_people"
        app:layout_constraintTop_toBottomOf="@id/tv_report_people" />

    <TextView
        android:id="@+id/tv_report_time_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="2025/6/20 14:02:05"
        android:textColor="#b2010101"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tv_report_time"
        app:layout_constraintStart_toEndOf="@+id/tv_report_time"
        app:layout_constraintTop_toTopOf="@id/tv_report_time" />

    <LinearLayout
        android:id="@+id/ll_report_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="@id/tv_report_time"
        app:layout_constraintTop_toBottomOf="@id/tv_report_time">

        <TextView
            android:id="@+id/tv_report_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/report_desc"
            android:textColor="#b2010101"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_report_desc_value"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginEnd="13dp"
            android:textColor="#b2010101"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tv_report_desc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_report_desc"
            app:layout_constraintTop_toTopOf="@id/tv_report_desc"
            tools:text="这里是用户填写的这里是用户填写的这里是用户填写的这里是用户填写的这里是用户填写的这里是用户填写的这里是用户填写的这里是用户填写的这里是用户填写的这里是用户填写的这里是用户填写的" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_report_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/report_type"
        android:textColor="#b2010101"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="@id/ll_report_desc"
        app:layout_constraintTop_toBottomOf="@id/ll_report_desc" />

    <TextView
        android:id="@+id/tv_report_type_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="色情"
        android:textColor="#b2010101"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tv_report_type"
        app:layout_constraintStart_toEndOf="@+id/tv_report_type"
        app:layout_constraintTop_toTopOf="@id/tv_report_type" />

    <TextView
        android:id="@+id/tv_report_material"
        android:layout_width="54dp"
        android:layout_height="19dp"
        android:layout_marginTop="10dp"
        android:text="@string/report_material"
        android:textStyle="bold"
        android:textColor="#d9010101"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="@id/tv_report_type"
        app:layout_constraintTop_toBottomOf="@id/tv_report_type" />

    <TextView
        android:id="@+id/tv_report_material_no"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="无"
        android:textColor="#d9010101"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/tv_report_material"
        app:layout_constraintTop_toBottomOf="@id/tv_report_material" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_report_material"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintStart_toStartOf="@id/tv_report_material"
        app:layout_constraintTop_toBottomOf="@id/tv_report_material" />

    <TextView
        android:id="@+id/tv_report_result"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="13dp"
        android:text="@string/report_result"
        android:textColor="#d9010101"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@id/tv_report_material"
        app:layout_constraintTop_toBottomOf="@id/rv_report_material" />

    <TextView
        android:id="@+id/tv_report_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/shape_f7f7f7_r8"
        android:paddingHorizontal="13dp"
        android:paddingVertical="6dp"
        tools:text="审核通过"
        android:textStyle="bold"
        android:textColor="#ff34c759"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@id/tv_report_result"
        app:layout_constraintTop_toBottomOf="@id/tv_report_result" />
</androidx.constraintlayout.widget.ConstraintLayout>