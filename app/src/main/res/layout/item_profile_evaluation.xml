<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
        android:id="@+id/iv_avatar"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:scaleType="centerCrop"
        app:corner_radius="42dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@color/black" />

    <TextView
        android:id="@+id/tv_nick_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:ellipsize="end"
        android:lines="1"
        android:maxWidth="90dp"
        android:textColor="#d9010101"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/iv_avatar"
        app:layout_constraintTop_toTopOf="@id/iv_avatar"
        app:layout_constraintBottom_toBottomOf="@id/iv_avatar"
        tools:text="三角洲端游" />

    <TextView
        android:id="@+id/tv_create_time"
        android:layout_width="86dp"
        android:layout_height="13dp"
        android:layout_marginStart="4dp"
        android:textColor="#33010101"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@id/tv_nick_name"
        app:layout_constraintStart_toEndOf="@id/tv_nick_name"
        app:layout_constraintTop_toTopOf="@id/tv_nick_name"
        tools:text="2025-09-21  09:21" />

    <RatingBar
        android:id="@+id/ratingBar"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:theme="@style/RatingBarTheme"
        app:layout_constraintBottom_toBottomOf="@id/iv_avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_avatar" />

    <TextView
        android:id="@+id/tv_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#b3010101"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tv_nick_name"
        app:layout_constraintTop_toBottomOf="@id/iv_avatar"
        tools:text="真心推荐，卖相佳，价格实在，服务贴心。吃得超开心，下回一定再来。真心推荐，卖相佳，价格实在，服务贴心。吃得超开心，下回一定再来。" />
</androidx.constraintlayout.widget.ConstraintLayout>