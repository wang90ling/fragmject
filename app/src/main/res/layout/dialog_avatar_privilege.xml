<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="#ff000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/parent_dialog"
        android:layout_width="match_parent"
        android:layout_height="444dp"
        android:layout_gravity="bottom"
        android:background="@drawable/person_info_privilege_bg"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/dialog_top_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/dialog_title_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
            </androidx.constraintlayout.widget.ConstraintLayout>
            <ImageView
                android:id="@+id/dialog_icon"
                android:layout_width="42dp"
                android:layout_height="21dp"
                android:src="@drawable/person_info_privilege_icon"
                android:layout_marginStart="17dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="23dp"
                android:gravity="center"
                android:textColor="@color/color_40_010101"
                android:textSize="12sp"
                android:text="动态头像说明"
                android:fontFamily="sans-serif"
                android:layout_marginStart="5dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/dialog_icon"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/dialog_avatar_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@+id/dialog_top_layout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageView
                android:id="@+id/dialog_avatar_bg"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/dialog_privilege_avatar_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
                android:id="@+id/dialog_avatar"
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:scaleType="centerCrop"
                app:corner_radius="50dp"
                app:layout_constraintTop_toTopOf="@+id/dialog_avatar_bg"
                app:layout_constraintBottom_toBottomOf="@+id/dialog_avatar_bg"
                app:layout_constraintStart_toStartOf="@+id/dialog_avatar_bg"
                app:layout_constraintEnd_toEndOf="@+id/dialog_avatar_bg" />
            <ImageView
                android:id="@+id/dialog_avatar_tips"
                android:layout_width="58dp"
                android:layout_height="19dp"
                android:src="@drawable/person_info_privilege_avatar_tips"
                android:layout_marginStart="63dp"
                android:layout_marginBottom="79dp"
                app:layout_constraintBottom_toBottomOf="@+id/dialog_avatar_bg"
                app:layout_constraintStart_toStartOf="@+id/dialog_avatar_bg"/>
            <TextView
                android:id="@+id/dialog_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="动态头像"
                android:textColor="#944822"
                android:textSize="14sp"
                android:fontFamily="@font/montserrat_medium"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@+id/dialog_avatar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/dialog_privilege_bottom_bg"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@+id/dialog_avatar_layout"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/dialog_get"
                android:layout_width="wrap_content"
                android:layout_height="19dp"
                android:gravity="left"
                android:text="如何获得："
                android:textColor="#944822"
                android:textSize="13sp"
                android:layout_marginTop="13dp"
                android:layout_marginHorizontal="13dp"
                android:fontFamily="@font/montserrat_medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
            <TextView
                android:id="@+id/dialog_get_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="left"
                android:text="参加运营活动可以获得该特权。"
                android:fontFamily="@font/montserrat_medium"
                android:textColor="#99944822"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="13dp"
                app:layout_constraintTop_toBottomOf="@+id/dialog_get"
                app:layout_constraintStart_toStartOf="parent" />
            <TextView
                android:id="@+id/dialog_update"
                android:layout_width="wrap_content"
                android:layout_height="19dp"
                android:gravity="left"
                android:text="如何上传："
                android:textColor="#944822"
                android:textSize="13sp"
                android:layout_marginTop="13dp"
                android:layout_marginHorizontal="13dp"
                android:fontFamily="@font/montserrat_medium"
                app:layout_constraintTop_toBottomOf="@+id/dialog_get_content"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/dialog_update_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="left"
                android:text="获得特权后，支持上传方形GIF格式动画作为头像，文件需小于5MB。"
                android:fontFamily="@font/montserrat_medium"
                android:textColor="#99944822"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="13dp"
                app:layout_constraintTop_toBottomOf="@+id/dialog_update"
                app:layout_constraintStart_toStartOf="parent"/>
            <TextView
                android:id="@+id/dialog_update_content_two"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="left"
                android:text="特权过期后会恢复为静态头像。"
                android:fontFamily="@font/montserrat_medium"
                android:textColor="#99944822"
                android:textSize="12sp"
                android:paddingHorizontal="13dp"
                app:layout_constraintTop_toBottomOf="@+id/dialog_update_content"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/dialog_ok_btn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginHorizontal="4dp"
                android:layout_marginTop="15dp"
                android:background="@drawable/shape_def_button"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/dialog_update_content_two">

                <TextView
                    android:id="@+id/ok_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="13dp"
                    android:gravity="center"
                    android:text="知道了"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>