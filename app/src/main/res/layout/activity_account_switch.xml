<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <View
        android:id="@+id/top_view"
        android:layout_width="match_parent"
        android:layout_height="1px"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleType="fitXY"
        android:src="@drawable/ic_account_switch_top_bg"
        app:layout_constraintDimensionRatio="360:145"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/top_view" />

    <pw.z.baselibrary.view.CustomTitleBar
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        app:layout_constraintTop_toBottomOf="@id/top_view"
        app:moreIcon="@drawable/ic_doubt"
        app:moreType="icon"
        app:showMore="true"
        app:titleText="账号切换" />

    <com.small.uikit.ui.layout.UiConstraintLayout
        android:id="@+id/ll_account_switch_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="13dp"
        android:layout_marginTop="19dp"
        app:background_normal="@color/white"
        app:corner_radius="10dp"
        app:layout_constraintTop_toBottomOf="@id/titleBar">

        <LinearLayout
            android:id="@+id/ll_phone_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_account_switch_phone_bg"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_phone_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="17dp"
                android:layout_marginTop="5dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                tools:text="当前手机号：150****7777" />

            <TextView
                android:id="@+id/tv_bind_account_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="17dp"
                android:layout_marginTop="3dp"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                app:layout_constraintTop_toBottomOf="@id/tv_phone_number"
                tools:text="已绑定 3 个账号，还可再绑定 0 个" />

        </LinearLayout>

        <com.small.uikit.ui.layout.UiConstraintLayout
            android:id="@+id/ll_bind_account_1"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/ll_phone_info"
            tools:visibility="visible">

            <com.small.uikit.ui.view.UiImageView
                android:id="@+id/iv_avatar_1"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="17dp"
                android:scaleType="centerCrop"
                app:corner_radius="100dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@id/iv_avatar_1"
                app:layout_constraintEnd_toStartOf="@id/cb_account_1"
                app:layout_constraintStart_toEndOf="@id/iv_avatar_1"
                app:layout_constraintTop_toTopOf="@id/iv_avatar_1">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_account_name_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_80_010101"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="张弛有度收放同心" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_level_layout_1"
                        android:layout_width="0dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="3dp"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/tv_account_name_1"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/tv_level_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_marginEnd="4dp"
                            android:fontFamily="@font/d_dinexp"
                            android:gravity="center_vertical"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="251" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/tv_account_id_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/color_50_010101"
                    android:textSize="12sp"
                    tools:text="ID:000000" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="13dp"
                android:layout_marginBottom="1dp"
                android:text="最近登录"
                android:textColor="#8C7DFC"
                android:textSize="12sp"
                app:layout_constraintBottom_toTopOf="@id/iv_avatar_1"
                app:layout_constraintEnd_toEndOf="parent" />

            <CheckBox
                android:id="@+id/cb_account_1"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_marginEnd="27dp"
                android:background="@drawable/custom_checkbox"
                android:button="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </com.small.uikit.ui.layout.UiConstraintLayout>

        <com.small.uikit.ui.layout.UiConstraintLayout
            android:id="@+id/ll_bind_account_2"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/ll_bind_account_1"
            tools:visibility="visible">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_10_010101"
                app:layout_constraintTop_toTopOf="parent" />

            <com.small.uikit.ui.view.UiImageView
                android:id="@+id/iv_avatar_2"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="17dp"
                android:scaleType="centerCrop"
                app:corner_radius="100dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@id/iv_avatar_2"
                app:layout_constraintEnd_toStartOf="@id/cb_account_2"
                app:layout_constraintStart_toEndOf="@id/iv_avatar_2"
                app:layout_constraintTop_toTopOf="@id/iv_avatar_2">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_account_name_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_80_010101"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="张弛有度收放同心" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_level_layout_2"
                        android:layout_width="0dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="3dp"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/tv_account_name_2"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/tv_level_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_marginEnd="4dp"
                            android:fontFamily="@font/d_dinexp"
                            android:gravity="center_vertical"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="251" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/tv_account_id_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/color_50_010101"
                    android:textSize="12sp"
                    tools:text="ID:000000" />

            </LinearLayout>

            <CheckBox
                android:id="@+id/cb_account_2"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_marginEnd="27dp"
                android:background="@drawable/custom_checkbox"
                android:button="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </com.small.uikit.ui.layout.UiConstraintLayout>

        <com.small.uikit.ui.layout.UiConstraintLayout
            android:id="@+id/ll_bind_account_3"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/ll_bind_account_2"
            tools:visibility="visible">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_10_010101"
                app:layout_constraintTop_toTopOf="parent" />

            <com.small.uikit.ui.view.UiImageView
                android:id="@+id/iv_avatar_3"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="17dp"
                android:scaleType="centerCrop"
                app:corner_radius="100dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@id/iv_avatar_3"
                app:layout_constraintEnd_toStartOf="@id/cb_account_3"
                app:layout_constraintStart_toEndOf="@id/iv_avatar_3"
                app:layout_constraintTop_toTopOf="@id/iv_avatar_3">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_account_name_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_80_010101"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="张弛有度收放同心" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_level_layout_3"
                        android:layout_width="0dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="3dp"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/tv_account_name_3"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/tv_level_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_marginEnd="4dp"
                            android:fontFamily="@font/d_dinexp"
                            android:gravity="center_vertical"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="251" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/tv_account_id_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/color_50_010101"
                    android:textSize="12sp"
                    tools:text="ID:000000" />

            </LinearLayout>

            <CheckBox
                android:id="@+id/cb_account_3"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_marginEnd="27dp"
                android:background="@drawable/custom_checkbox"
                android:button="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </com.small.uikit.ui.layout.UiConstraintLayout>

    </com.small.uikit.ui.layout.UiConstraintLayout>

    <TextView
        android:id="@+id/tv_add_account_small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="13dp"
        android:text="添加账号"
        android:textColor="@color/color_40_010101"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_account_switch_content"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tv_add_account"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="13dp"
        android:layout_marginTop="19dp"
        android:background="@drawable/shape_def_button_r10"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="+ 添加新账号"
        android:textColor="#FEFEFF"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/tv_add_account_small" />

    <TextView
        android:id="@+id/tv_enter"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="13dp"
        android:layout_marginTop="19dp"
        android:background="@drawable/shape_def_button_r10"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="立即进入"
        android:textColor="#FEFEFF"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_add_account_small" />

</androidx.constraintlayout.widget.ConstraintLayout>