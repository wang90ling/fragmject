<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <View
        android:id="@+id/top_view"
        android:layout_width="match_parent"
        android:layout_height="1px"
        app:layout_constraintTop_toTopOf="parent" />
    <ImageView
        android:id="@+id/top_bg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_conversation_top_bg2"
        app:layout_constraintDimensionRatio="360:213"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/top_bg_bottom"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/shape_conversation_top_bg"
        app:layout_constraintBottom_toBottomOf="@+id/top_bg"
        app:layout_constraintDimensionRatio="360:82" />

    <!--<com.opensource.svgaplayer.SVGAImageView
        android:id="@+id/svga_main_top_bg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:autoPlay="true"
        app:layout_constraintDimensionRatio="360:306"
        app:layout_constraintTop_toTopOf="parent"
        app:source="main_top_bg.svga" />-->


    <TextView
        android:id="@+id/message_title"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="13dp"
        android:text="@string/message_title"
        android:textColor="@color/color_85_000000"
        android:textSize="21sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/top_view" />

    <ImageView
        android:id="@+id/message_clear"
        android:layout_width="23dp"
        android:layout_height="23dp"
        android:src="@drawable/ic_message_clear_btn"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toTopOf="@+id/message_title"
        app:layout_constraintBottom_toBottomOf="@+id/message_title"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/create_group_iv"
        android:layout_width="23dp"
        android:layout_height="23dp"
        android:layout_marginEnd="13dp"
        android:src="@drawable/ic_conversation_create_group"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/message_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/message_title" />

    <com.yanzhenjie.recyclerview.SwipeRecyclerView
        android:id="@+id/conversation_rv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/message_title" />


</androidx.constraintlayout.widget.ConstraintLayout>
