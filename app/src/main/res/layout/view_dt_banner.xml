<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="333:86"
        app:layout_constraintTop_toTopOf="parent">

        <com.zhpan.bannerview.BannerViewPager
            android:id="@+id/recommend_banner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:bvp_auto_play="true"
            app:bvp_can_loop="true"
            app:bvp_indicator_checked_color="@color/color_FFFFFF"
            app:bvp_indicator_gravity="center"
            app:bvp_indicator_normal_color="#80FFFFFF"
            app:bvp_indicator_style="round_rect"
            app:bvp_interval="3000"
            app:bvp_scroll_duration="300" />
    </FrameLayout>


</androidx.constraintlayout.widget.ConstraintLayout>