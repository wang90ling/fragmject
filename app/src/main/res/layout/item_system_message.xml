<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/system_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:lines="1"
        android:maxLines="1"
        android:singleLine="true"
        android:textColor="#4D000000"
        android:textSize="10sp"
        android:fontFamily="@font/montserrat_regular"
        tools:text="2025-2 下午 2：00"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />


    <LinearLayout
        android:id="@+id/system_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="31dp"
        android:paddingLeft="13dp"
        android:paddingRight="13dp"
        android:paddingBottom="13dp"
        android:orientation="vertical"
        android:background="@drawable/system_notification_item_bg"
        app:layout_constraintTop_toBottomOf="@+id/system_time">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/common_message_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/system_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:text=""
                android:textColor="#d9000000"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="标题" />
            <TextView
                android:id="@+id/system_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="14dp"
                android:text=""
                android:textColor="#d9010101"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@+id/system_title"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/radio_message_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="13dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:id="@+id/radio_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:maxLines="1"
                android:lineHeight="23dp"
                android:ellipsize="end"
                android:text=""
                android:textColor="#d9000000"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat_medium"
                app:layout_constraintEnd_toStartOf="@+id/radio_time"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="电台" />

            <ImageView
                android:id="@+id/radio_time_icon"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/ic_radio_station_msg"
                android:layout_marginEnd="-6dp"
                app:layout_constraintEnd_toStartOf="@+id/radio_time"
                app:layout_constraintTop_toTopOf="@+id/radio_title"
                app:layout_constraintBottom_toBottomOf="@+id/radio_title" />

            <TextView
                android:id="@+id/radio_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lineHeight="13dp"
                android:text=""
                android:gravity="center"
                android:textColor="@color/color_50_010101"
                android:textSize="10sp"
                android:fontFamily="@font/d_dinexp"
                android:background="@drawable/bg_radio_time"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/radio_title"
                app:layout_constraintBottom_toBottomOf="@+id/radio_title"
                tools:text="11:00-12:00"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/radio_title">

                <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
                    android:id="@+id/radio_room_icon"
                    android:layout_width="66dp"
                    android:layout_height="66dp"
                    android:layout_marginTop="17dp"
                    android:layout_marginBottom="10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/drawable_placeholder"
                    app:corner_radius="7dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0" />

                <TextView
                    android:id="@+id/radio_column_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ic_column_small_label"
                    android:includeFontPadding="false"
                    android:layout_marginTop="9dp"
                    android:paddingHorizontal="8dp"
                    android:textColor="#ff661f15"
                    android:textSize="10sp"
                    android:lineHeight="13dp"
                    android:fontFamily="@font/montserrat_regular"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="趣味知识" />


                <TextView
                    android:id="@+id/radio_column_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text=""
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/color_85_010101"
                    android:lineHeight="16dp"
                    android:textSize="12sp"
                    android:fontFamily="@font/montserrat_medium"
                    app:layout_constraintStart_toEndOf="@+id/radio_room_icon"
                    app:layout_constraintTop_toTopOf="@+id/radio_room_icon"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="回声播客"/>

                <TextView
                    android:id="@+id/radio_column_schedule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="6dp"
                    android:lineHeight="13dp"
                    android:text=""
                    android:maxWidth="200dp"
                    android:textColor="#F5B942"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:background="@drawable/bg_radio_column_schedule"
                    android:paddingHorizontal="8dp"

                    app:layout_constraintStart_toEndOf="@+id/radio_room_icon"
                    app:layout_constraintTop_toBottomOf="@+id/radio_column_name"
                    tools:text="开心话题"/>

                <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
                    android:id="@+id/streamer_icon"
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:layout_marginTop="8dp"
                    android:scaleType="centerCrop"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/drawable_placeholder"
                    app:layout_constraintStart_toEndOf="@+id/radio_room_icon"
                    app:layout_constraintTop_toBottomOf="@+id/radio_column_schedule"
                    app:corner_radius="21dp" />
                <TextView
                    android:id="@+id/streamer_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/color_30_010101"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="4dp"
                    app:layout_constraintStart_toEndOf="@+id/streamer_icon"
                    app:layout_constraintBottom_toBottomOf="@+id/streamer_icon"
                    app:layout_constraintTop_toTopOf="@+id/streamer_icon"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="石家庄"/>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/system_url_layout"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            app:layout_constraintTop_toBottomOf="@+id/common_message_layout"
            android:visibility="visible">
            <ImageView
                android:id="@+id/system_line"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#0D000000"
                android:layout_marginBottom="10dp"/>
            <TextView
                android:id="@+id/system_url"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="查看详情"
                android:textColor="#ff8c7dfc"
                android:textSize="14sp"
                android:fontFamily="@font/montserrat_regular"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
            <ImageView
                android:id="@+id/system_icon"
                android:layout_width="18dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:src="@drawable/ic_message_arrow"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>