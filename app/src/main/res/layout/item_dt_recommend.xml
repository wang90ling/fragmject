<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="13dp"
        android:background="@drawable/ic_home_recommend_bg"
        app:layout_constraintDimensionRatio="333:100"
        app:layout_constraintTop_toTopOf="parent">

        <com.tencent.qcloud.tuikit.deskcommon.component.RoundCornerImageView
            android:id="@+id/recommend_avatar"
            android:layout_width="77dp"
            android:layout_height="77dp"
            android:layout_margin="12dp"
            app:corner_radius="77dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <pw.z.baselibrary.view.DtSVGAImageView
            android:id="@+id/recommend_avatar_frame"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="@id/recommend_avatar"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="@id/recommend_avatar"
            app:layout_constraintStart_toStartOf="@id/recommend_avatar"
            app:layout_constraintTop_toTopOf="@id/recommend_avatar" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingEnd="12dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/recommend_avatar_frame"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_recommend_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="3dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_chat"
                app:layout_constraintEnd_toStartOf="@id/iv_online_state"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/iv_chat">

                <pw.z.imchat.feature.dressup.view.GradientTextView
                    android:id="@+id/recommend_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="1dp"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:lines="1"
                    android:maxWidth="111dp"
                    android:singleLine="true"
                    android:textColor="@color/color_85_010101"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constrainedWidth="true"
                    app:layout_constraintEnd_toStartOf="@+id/ll_recommend_name"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="七七七七七七七七七七七七七七七七七七七七七七七七" />

                <LinearLayout
                    android:id="@+id/ll_recommend_name"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintBottom_toBottomOf="@+id/recommend_name"
                    app:layout_constraintStart_toEndOf="@id/recommend_name"
                    app:layout_constraintTop_toTopOf="@+id/recommend_name">

                    <ImageView
                        android:id="@+id/sex_iv"
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:layout_marginStart="3dp"
                        app:layout_constraintBottom_toBottomOf="@+id/recommend_name"
                        app:layout_constraintStart_toEndOf="@+id/recommend_name"
                        app:layout_constraintTop_toTopOf="@+id/recommend_name" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/room_level_layout"
                        android:layout_width="wrap_content"
                        android:layout_height="16dp"
                        android:layout_marginStart="3dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/sex_iv"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/room_level"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_marginEnd="4dp"
                            android:fontFamily="@font/d_dinexp"
                            android:gravity="center_vertical"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="251" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <ImageView
                android:id="@+id/iv_online_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/drawable_online"
                app:layout_constraintBottom_toBottomOf="@id/iv_chat"
                app:layout_constraintEnd_toStartOf="@id/iv_chat"
                app:layout_constraintTop_toTopOf="@id/iv_chat" />

            <TextView
                android:id="@+id/iv_chat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:includeFontPadding="false"
                android:text="@string/recommend_online"
                android:textColor="@color/color_40_010101"
                android:textSize="10sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <pw.z.dianta.view.RecommendGameInfoView
                android:id="@+id/game_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constrainedWidth="true"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/cl_recommend_name"
                app:layout_constraintTop_toBottomOf="@+id/cl_recommend_name" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/voice_info_cl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:background="@drawable/shape_home_recomend_voice_bg"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                app:layout_constraintStart_toStartOf="@+id/cl_recommend_name"
                app:layout_constraintTop_toBottomOf="@+id/game_info">

                <ImageView
                    android:id="@+id/voice_state_iv"
                    android:layout_width="15dp"
                    android:layout_height="0dp"
                    android:src="@drawable/ic_home_voice_play"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <FrameLayout
                    android:id="@+id/fl_voice_anim"
                    android:layout_width="14dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="5dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/voice_state_iv"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/voice_playing_iv"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_home_recommend_voice" />

                    <com.opensource.svgaplayer.SVGAImageView
                        android:id="@+id/iv_voice_anim"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone"
                        app:autoPlay="false"
                        app:source="ic_voice_anim.svga" />

                </FrameLayout>

                <TextView
                    android:id="@+id/voice_state_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:textColor="@color/color_8C7DFC"
                    android:textSize="10sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/fl_voice_anim"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="7''" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/price_num_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="@color/color_8C7DFC"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/price_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textColor="@color/color_30_010101"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
