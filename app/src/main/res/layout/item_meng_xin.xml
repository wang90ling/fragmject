<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/common_message_layout"
        android:layout_width="match_parent"
        android:layout_height="104dp"
        android:background="@drawable/bg_mengxin_item"
        app:layout_constraintTop_toTopOf="parent">

        <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
            android:id="@+id/user_icon"
            android:layout_width="83dp"
            android:layout_height="83dp"
            android:layout_marginStart="11dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_room_default"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:corner_radius="12dp" />

        <ImageView
            android:id="@+id/user_recommend"
            android:layout_width="60dp"
            android:layout_height="14dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_mengxin_recommend"
            app:layout_constraintTop_toTopOf="@+id/user_icon"
            app:layout_constraintStart_toStartOf="@+id/user_icon"
            app:corner_radius="12dp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/user_mid_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@+id/user_icon"
            app:layout_constraintBottom_toBottomOf="@+id/user_icon"
            app:layout_constraintStart_toEndOf="@+id/user_icon"
            app:layout_constraintEnd_toStartOf="@+id/user_end_layout">
            <TextView
                android:id="@+id/user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/color_85_010101"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="标题" />
            <LinearLayout
                android:id="@+id/user_info_layout"
                android:layout_width="wrap_content"
                android:layout_height="13dp"
                android:layout_marginStart="6dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_mengxin_man"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="@+id/user_name"
                app:layout_constraintBottom_toBottomOf="@+id/user_name"
                app:layout_constraintStart_toEndOf="@+id/user_name"
                tools:visibility="visible">
                <ImageView
                    android:id="@+id/user_info_sex"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_profile_sex_man_room" />
                <TextView
                    android:id="@+id/user_info_age"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginBottom="1dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    tools:text="23" />
            </LinearLayout>


            <ImageView
                android:id="@+id/user_high_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="19dp"
                android:src="@drawable/ic_mengxin_high_value"
                app:layout_constraintTop_toBottomOf="@+id/user_name"
                app:layout_constraintStart_toStartOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/user_end_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="23dp"
            app:layout_constraintTop_toTopOf="@+id/user_icon"
            app:layout_constraintBottom_toBottomOf="@+id/user_icon"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/user_liao_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="12dp"
                android:textColor="@color/color_30_010101"
                app:layout_constraintBottom_toTopOf="@+id/user_liao_btn"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="剩余5次" />

            <ImageView
                android:id="@+id/user_liao_btn"
                android:layout_width="53dp"
                android:layout_height="27dp"
                android:src="@drawable/ic_mengxin_liao"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>



</androidx.constraintlayout.widget.ConstraintLayout>