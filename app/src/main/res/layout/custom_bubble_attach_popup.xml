<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="102dp"
    android:layout_height="102dp"
    android:background="@drawable/ic_accet_setting_more_bubble">

    <LinearLayout
        android:layout_width="83dp"
        android:layout_height="83dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingTop="6dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_onekey_close_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="7dp"
            android:gravity="center"
            android:text="@string/onekey_close_all"
            android:textColor="#d9010101"
            android:textSize="13sp" />

        <View
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:background="#1a010101" />

        <TextView
            android:id="@+id/tv_onekey_open_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:gravity="center"
            android:text="@string/onekey_open_all"
            android:textColor="#d9010101"
            android:textSize="13sp" />
    </LinearLayout>
</FrameLayout>