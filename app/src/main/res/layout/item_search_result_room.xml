<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="98dp"
    android:layout_marginVertical="5dp"
    android:background="@drawable/shape_bg_popular_companionship">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="6dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_ffffff_r10" />

        <com.tencent.qcloud.tuikit.timcommon.component.RoundCornerImageView
            android:id="@+id/iv_room_icon"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:scaleType="centerCrop"
            app:corner_radius="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@color/black" />

        <TextView
            android:id="@+id/tv_join"
            android:layout_width="38dp"
            android:layout_height="15dp"
            android:background="@drawable/ic_search_room_state_bg"
            android:gravity="center"
            android:text="交友"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/iv_room_icon"
            app:layout_constraintTop_toTopOf="@id/iv_room_icon" />

        <TextView
            android:id="@+id/tv_room_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginTop="6dp"
            android:textColor="@color/color_85_010101"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/iv_room_icon"
            app:layout_constraintTop_toTopOf="@id/iv_room_icon"
            tools:text="永劫无间官方社区" />

        <TextView
            android:id="@+id/tv_room_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginTop="4dp"
            android:textColor="@color/color_20_010101"
            android:textSize="13sp"
            app:layout_constraintStart_toEndOf="@+id/iv_room_icon"
            app:layout_constraintTop_toBottomOf="@id/tv_room_name"
            tools:text="ID：1234" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginBottom="6dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@id/iv_room_icon"
            app:layout_constraintStart_toEndOf="@id/iv_room_icon">

            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/ic_room_owner_default"/>

            <TextView
                android:id="@+id/tv_owner_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                tools:text="歌手小美" />

            <ImageView
                android:id="@+id/iv_search_room_anim"
                android:layout_width="14dp"
                android:layout_height="10dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="6dp"
                android:layout_marginTop="3dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_hot_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/shape_bg_hot_value"
            android:drawableStart="@drawable/ic_channel_hot"
            android:drawablePadding="1dp"
            android:paddingHorizontal="3dp"
            android:paddingVertical="2dp"
            android:textColor="#B2FE606F"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/iv_room_icon"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="251" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>