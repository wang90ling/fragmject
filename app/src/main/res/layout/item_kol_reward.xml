<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- 圆形奖励图标背景 -->
    <FrameLayout
        android:id="@+id/fl_reward_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/ic_kol_reward_item_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 奖励图片 -->
        <pw.z.baselibrary.view.DtSVGAImageView
            android:id="@+id/iv_reward"
            android:layout_width="47dp"
            android:layout_height="47dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop" />

    </FrameLayout>

    <!-- 右上角标签（如 x2, 15天） -->
    <TextView
        android:id="@+id/tv_reward_tag"
        android:layout_width="23dp"
        android:layout_height="12dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/ic_kol_reward_days_bg"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="8sp"
        app:layout_constraintBottom_toBottomOf="@id/fl_reward_icon"
        app:layout_constraintEnd_toEndOf="@id/fl_reward_icon"
        tools:text="15天" />

    <!-- 奖励名称 -->
    <TextView
        android:id="@+id/tv_reward_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#CCFFFFFF"
        android:textSize="9sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fl_reward_icon"
        tools:text="95折优惠券" />

    <TextView
        android:id="@+id/tv_reward_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/white"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="parent"
        android:drawablePadding="2dp"
        android:drawableStart="@drawable/dt_c_drawable_star_diamond12"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_reward_name"
        tools:text="1000" />

</androidx.constraintlayout.widget.ConstraintLayout>
