<?xml version="1.0" encoding="utf-8"?>
<layout>

    <data>

        <variable
            name="itemInfo"
            type="pw.z.dianta.feature.orderpush.bean.UserSkuPriceOrderDto" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:paddingBottom="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="13dp"
            android:background="@drawable/ic_home_recommend_bg"
            app:layout_constraintDimensionRatio="333:100"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/recommend_avatar"
                android:layout_width="77dp"
                android:layout_height="77dp"
                android:layout_margin="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:loadCircleImage="@{itemInfo.userInfo.avatar}" />

            <ImageView
                android:id="@+id/recommend_avatar_frame"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="3dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="@+id/recommend_avatar"
                app:layout_constraintStart_toStartOf="@+id/recommend_avatar" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingEnd="12dp"
                app:layout_constrainedWidth="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/recommend_avatar_frame"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/recommend_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="1dp"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:lines="1"
                    android:maxLength="10"
                    android:singleLine="true"
                    android:text="@{itemInfo.userInfo.nickName}"
                    android:textColor="@color/color_85_010101"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constrainedWidth="true"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_chat"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/iv_chat"
                    tools:text="七七七七七七七七七七七七七七七七七七七七七七七七" />

                <LinearLayout
                    android:id="@+id/ll_sex_age"
                    android:layout_width="wrap_content"
                    android:layout_height="15dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_profile_sex_age_m"
                    android:gravity="center_vertical"
                    android:minHeight="16dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="3dp"
                    app:layout_constraintBottom_toBottomOf="@+id/recommend_name"
                    app:layout_constraintStart_toEndOf="@+id/recommend_name"
                    app:layout_constraintTop_toTopOf="@+id/recommend_name">

                    <ImageView
                        android:id="@+id/sex_iv"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        tools:src="@drawable/ic_profile_sex_man" />

                    <TextView
                        android:id="@+id/tv_age"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        tools:text="23" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_chat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:includeFontPadding="false"
                    android:src="@drawable/ic_chat_with_bg"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <pw.z.dianta.view.RecommendGameInfoView
                    android:id="@+id/game_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constrainedWidth="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/recommend_name"
                    app:layout_constraintTop_toBottomOf="@+id/iv_chat" />

                <LinearLayout
                    android:id="@+id/voice_info_cl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/recommend_name">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_medium"
                        android:textColor="@color/color_8C7DFC"
                        android:textSize="19sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:textDecimalFormat="@{itemInfo.userCustomPrice}"
                        tools:text="48" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_marginBottom="2dp"
                        android:text="钻/小时"
                        android:textColor="@color/color_30_010101"
                        android:textSize="10sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="@id/voice_info_cl"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:id="@+id/iv_remove"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_minus" />

                    <TextView
                        android:id="@+id/price_num_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginHorizontal="11dp"
                        android:gravity="center"
                        android:text='@{itemInfo.quantity > 0 ? "" + itemInfo.quantity : "1"}'
                        android:textColor="@color/color_010101"
                        android:textSize="13sp"
                        tools:text="1" />

                    <ImageView
                        android:id="@+id/iv_add"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_add" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>