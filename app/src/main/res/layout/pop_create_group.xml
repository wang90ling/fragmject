<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/create_group_tv"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/ic_create_group_bg"
        android:drawableStart="@drawable/drawable_create_group"
        android:gravity="center"
        android:includeFontPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingTop="2dp"
        android:text="@string/conversation_start_group_chat"
        android:textColor="@color/color_696B9D"
        android:textSize="15sp"
        app:layout_constraintDimensionRatio="259:108"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>